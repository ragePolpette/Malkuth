{
  "name": "malkuth-local-ticket-harness",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Local-first ticket triage and controlled execution harness with MCP-ready adapters.",
  "scripts": {
    "start": "node src/cli.js run",
    "dry-run": "node src/cli.js run --config ./config/harness.config.example.json --dry-run",
    "triage": "node src/cli.js triage --config ./config/harness.config.example.json --dry-run",
    "execute": "node src/cli.js execute --config ./config/harness.config.example.json --dry-run --report execution",
    "audit": "node src/cli.js audit --config ./config/harness.config.example.json",
    "review": "node src/cli.js review --config ./config/harness.config.example.json",
    "test": "node --test"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1"
  }
}
